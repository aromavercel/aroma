# ===========================================
# Copie este arquivo para .env e preencha.
# Nunca commite o .env (deve estar no .gitignore).
# ===========================================

# --- Obrigatórias para login/cadastro (email e senha) ---
DATABASE_URL=postgresql://usuario:senha@host/banco?sslmode=require
JWT_SECRET=gere-uma-chave-longa-e-aleatoria-para-producao

# --- Upload de foto de perfil (opcional) ---
# Crie um Blob store na Vercel (Storage). Sem isso, o botão "Enviar foto" não funciona.
# BLOB_READ_WRITE_TOKEN=

# --- Login com Google e Facebook (opcional) ---
# Sem essas variáveis, os botões "Google" e "Facebook" não funcionam (login por email/senha continua ok).
FRONTEND_URL=http://localhost:5173
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# --- Estimativa de entrega (Correios PAC) ---
# CEP de origem da loja (apenas dígitos). Sem isso, usa 01310100 (São Paulo).
# CORREIOS_CEP_ORIGEM=01310100

# --- Configuração SMTP (e-mail) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Aroma <contato@aromaexpresso.com>"
CONTACT_TO_EMAIL=contato@aromaexpresso.com

# --- Reset de senha via E-mail ---
# Opcional: configurações do token OTP
PASSWORD_RESET_TOKEN_TTL_MINUTES=10
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_COOLDOWN_SECONDS=60

# --- Desenvolvimento local ---
# Só necessário se o front roda em outro endereço (ex.: Vite em localhost:5173 e API em localhost:3001).
# Em produção na Vercel deixe em branco (front e API na mesma origem).
# VITE_API_URL=http://localhost:3001

# --- Links das redes (rodapé, topbar, contato, etc.) ---
# VITE_SOCIAL_WHATSAPP_URL=https://wa.me/5511999999999
# VITE_SOCIAL_INSTAGRAM_URL=https://www.instagram.com/seu_perfil/
